// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum OrderStatus {
  CREATED
  CONFIRMED
  PREPARING
  READY
  DELIVERED
}

enum Role {
  SUPER_ADMIN
  RESTAURANT_ADMIN
  MANAGER
  KITCHEN
  STAFF
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

// ─── SaaS Core Models ─────────────────────────────────────────────────────────

model SubscriptionPlan {
  id             String       @id @default(uuid())
  name           String       // "Starter", "Pro", "Enterprise"
  maxBranches    Int          @default(1)
  maxStaff       Int          @default(5)
  priceMonthly   Float
  features       Json?        // Feature gating flags
  restaurants    Restaurant[]
  createdAt      DateTime     @default(now())

  @@map("subscription_plans")
}

model Restaurant {
  id                 String             @id @default(uuid())
  slug               String             @unique // For subdomains: tenant.arifsmart.com
  name               String
  isActive           Boolean            @default(true)
  subscriptionStatus SubscriptionStatus @default(TRIALING)
  planId             String
  plan               SubscriptionPlan   @relation(fields: [planId], references: [id])
  themeConfig        Json?              // e.g. { "primaryColor": "#ff5500", "logoUrl": "..." }
  
  users              User[]
  branches           Branch[]
  categories         Category[]
  menuItems          MenuItem[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@map("restaurants")
}

// ─── Tenant-Scoped Models ─────────────────────────────────────────────────────

model Branch {
  id           String       @id @default(uuid())
  restaurantId String?      // [SaaS Phase 1: Nullable for now]
  name         String
  address      String
  phone        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  vatRate      Float        @default(15.0)
  serviceChargeRate Float   @default(10.0)
  
  restaurant   Restaurant?  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tables       DiningTable[]
  categories   Category[]
  users        User[]
  orderCounters BranchOrderCounter[]
  orderAudits  OrderAudit[]

  @@index([restaurantId])
  @@map("branches")
}

model BranchOrderCounter {
  id          String   @id @default(uuid())
  branchId    String
  counterDate String
  lastNumber  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, counterDate])
  @@map("branch_order_counters")
}

model DiningTable {
  id           String         @id @default(uuid())
  restaurantId String?        // [SaaS Phase 1: Nullable]
  branchId     String
  tableNumber  Int
  qrCode       String         @unique
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  
  branch       Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  sessions     TableSession[]
  orders       Order[]
  orderAudits  OrderAudit[]

  @@index([restaurantId])
  @@index([branchId])
  @@unique([branchId, tableNumber])
  @@map("dining_tables")
}

/// Prevents order conflicts: only one active session per table at a time.
model TableSession {
  id        String      @id @default(uuid())
  tableId   String
  isActive  Boolean     @default(true)
  startedAt DateTime    @default(now())
  endedAt   DateTime?
  table     DiningTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  orders    Order[]
  orderAudits OrderAudit[]

  @@map("table_sessions")
}

model Category {
  id               String     @id @default(uuid())
  restaurantId     String?    // [SaaS Phase 1: Nullable]
  name             String
  nameTranslations Json?      // { "am": "...", "or": "..." }
  sortOrder        Int        @default(0)
  imageUrl         String?
  branchId         String
  
  restaurant       Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  branch           Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  items            MenuItem[]
  createdAt        DateTime   @default(now())

  @@index([restaurantId])
  @@map("categories")
}

model MenuItem {
  id                      String      @id @default(uuid())
  restaurantId            String?     // [SaaS Phase 1: Nullable]
  name                    String
  nameTranslations        Json?       // { "am": "...", "or": "..." }
  description             String?
  descriptionTranslations Json?       // { "am": "...", "or": "..." }
  price                   Float
  isAvailable             Boolean     @default(true)
  isFasting               Boolean     @default(false)
  imageUrl                String?
  model3dUrl              String?
  categoryId              String
  
  restaurant              Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  category                Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems              OrderItem[]
  ratings                 Rating[]
  
  // CMS Relations
  ingredients Ingredient[]
  allergens   Allergen[]
  dietaryTags DietaryTag[]
  nutritionSections NutritionSection[]
  modifierGroups    ModifierGroup[]
  favorites         Favorite[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([restaurantId])
  @@map("menu_items")
}

model Order {
  id         String       @id @default(uuid())
  restaurantId String?    // [SaaS Phase 1: Nullable]
  tableId    String
  sessionId  String
  status     OrderStatus  @default(CREATED)
  displayNumber String
  subTotal      Float        @default(0)
  vatAmount     Float        @default(0)
  serviceChargeAmount Float  @default(0)
  totalPrice    Float
  customerRef   String
  paymentStatus String       @default("UNPAID")
  notes         String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  table      DiningTable  @relation(fields: [tableId], references: [id])
  session    TableSession @relation(fields: [sessionId], references: [id])
  items      OrderItem[]
  ratings    Rating[]
  audits     OrderAudit[]

  @@index([restaurantId])
  @@index([tableId])
  @@index([sessionId])
  @@map("orders")
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  menuItemId String
  quantity   Int
  unitPrice  Float
  note       String?
  options    OrderItemOption[]
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("order_items")
}

model User {
  id           String      @id @default(uuid())
  restaurantId String?     // Nullable ONLY for SUPER_ADMIN or Phase 1 migration
  branchId     String?     // Nullable if user has access to all branches
  name         String
  email        String?     @unique // For dashboard login
  passwordHash String?     // For email/password login
  pinHash      String?     // Kept for terminal login (optional)
  role         Role
  isActive     Boolean     @default(true)
  
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  branch       Branch?     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdAt    DateTime    @default(now())

  @@index([restaurantId])
  @@index([email])
  @@map("staff_users") // Mapped to old table name to prevent data loss
}

model Ingredient {
  id         String   @id @default(uuid())
  name       String
  detail     String?
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@map("ingredients")
}

model Allergen {
  id         String   @id @default(uuid())
  label      String
  present    Boolean  @default(false)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@map("allergens")
}

model DietaryTag {
  id         String   @id @default(uuid())
  label      String
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@map("dietary_tags")
}

model NutritionSection {
  id         String   @id @default(uuid())
  title      String
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  rows       NutritionRow[]

  @@map("nutrition_sections")
}

model NutritionRow {
  id               String           @id @default(uuid())
  nutrient         String
  amount           String
  dailyValue       String?
  sub              Boolean          @default(false)
  sectionId        String
  section          NutritionSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@map("nutrition_rows")
}

model ModifierGroup {
  id            String   @id @default(uuid())
  name          String   
  isRequired    Boolean  @default(false)
  minSelections Int      @default(0)
  maxSelections Int?
  menuItemId    String
  menuItem      MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  options       ModifierOption[]

  @@map("modifier_groups")
}

model ModifierOption {
  id              String   @id @default(uuid())
  name            String   
  price           Float    @default(0) 
  groupId         String
  group           ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  
  @@map("modifier_options")
}

model OrderItemOption {
  id              String   @id @default(uuid())
  orderItemId     String
  orderItem       OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  optionName      String   
  optionPrice     Float
  
  @@map("order_item_options")
}

model Rating {
  id          String    @id @default(uuid())
  orderId     String
  menuItemId  String?
  rating      Int
  comment     String?
  customerRef String
  createdAt   DateTime  @default(now())
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem    MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([customerRef])
  @@map("ratings")
}

model PushSubscription {
  id          String   @id @default(uuid())
  customerRef String   @unique
  endpoint    String   @unique
  p256dh      String
  auth        String
  createdAt   DateTime @default(now())

  @@map("push_subscriptions")
}

model Favorite {
  id          String   @id @default(uuid())
  customerRef String
  menuItemId  String
  createdAt   DateTime @default(now())

  menuItem    MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([customerRef, menuItemId])
  @@index([customerRef])
  @@map("favorites")
}

model OrderAudit {
  id            String   @id @default(uuid())
  restaurantId  String?  // [SaaS Phase 1: Nullable]
  branchId      String?
  tableId       String?
  sessionId     String?
  orderId       String?
  customerRef   String?
  displayNumber String?
  status        String
  source        String
  reason        String?
  itemCount     Int?
  createdAt     DateTime @default(now())

  branch        Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  table         DiningTable?  @relation(fields: [tableId], references: [id], onDelete: SetNull)
  session       TableSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  order         Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([restaurantId])
  @@index([branchId, createdAt])
  @@index([tableId, createdAt])
  @@index([sessionId, createdAt])
  @@index([orderId, createdAt])
  @@map("order_audits")
}
