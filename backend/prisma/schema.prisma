// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum OrderStatus {
  CREATED
  CONFIRMED
  PREPARING
  READY
  DELIVERED
}

enum Role {
  ADMIN
  KITCHEN
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Branch {
  id         String       @id @default(uuid())
  name       String
  address    String
  phone      String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  vatRate    Float        @default(15.0)
  serviceChargeRate Float @default(10.0)
  tables     DiningTable[]
  categories Category[]
  staffUsers StaffUser[]

  @@map("branches")
}

model DiningTable {
  id           String         @id @default(uuid())
  branchId     String
  tableNumber  Int
  qrCode       String         @unique
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  branch       Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  sessions     TableSession[]
  orders       Order[]

  @@unique([branchId, tableNumber])
  @@map("dining_tables")
}

/// Prevents order conflicts: only one active session per table at a time.
model TableSession {
  id        String      @id @default(uuid())
  tableId   String
  isActive  Boolean     @default(true)
  startedAt DateTime    @default(now())
  endedAt   DateTime?
  table     DiningTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  orders    Order[]

  @@map("table_sessions")
}

model Category {
  id               String     @id @default(uuid())
  name             String
  nameTranslations Json?      // { "am": "...", "or": "..." }
  sortOrder        Int        @default(0)
  imageUrl         String?
  branchId         String
  branch           Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  items            MenuItem[]
  createdAt        DateTime   @default(now())

  @@map("categories")
}

model MenuItem {
  id                      String      @id @default(uuid())
  name                    String
  nameTranslations        Json?       // { "am": "...", "or": "..." }
  description             String?
  descriptionTranslations Json?       // { "am": "...", "or": "..." }
  price                   Float
  isAvailable             Boolean     @default(true)
  isFasting               Boolean     @default(false)
  imageUrl                String?
  model3dUrl              String?
  categoryId              String
  category                Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems              OrderItem[]
  ratings                 Rating[]
  
  // CMS Relations
  ingredients Ingredient[]
  allergens   Allergen[]
  dietaryTags DietaryTag[]
  nutritionSections NutritionSection[]
  modifierGroups    ModifierGroup[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("menu_items")
}

model Order {
  id         String       @id @default(uuid())
  tableId    String
  sessionId  String
  status     OrderStatus  @default(CREATED)
  displayNumber String
  subTotal      Float        @default(0)
  vatAmount     Float        @default(0)
  serviceChargeAmount Float  @default(0)
  totalPrice    Float
  customerRef   String
  paymentStatus String       @default("UNPAID")
  notes         String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  table      DiningTable  @relation(fields: [tableId], references: [id])
  session    TableSession @relation(fields: [sessionId], references: [id])
  items      OrderItem[]
  ratings    Rating[]

  @@index([tableId])
  @@index([sessionId])
  @@map("orders")
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  menuItemId String
  quantity   Int
  unitPrice  Float
  note       String?
  options    OrderItemOption[]
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("order_items")
}

model StaffUser {
  id        String   @id @default(uuid())
  name      String
  role      Role
  pinHash   String
  branchId  String
  isActive  Boolean  @default(true)
  branch    Branch   @relation(fields: [branchId], references: [id])
  createdAt DateTime @default(now())

  @@map("staff_users")
}

model Ingredient {
  id         String   @id @default(uuid())
  name       String
  detail     String?
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@map("ingredients")
}

model Allergen {
  id         String   @id @default(uuid())
  label      String
  present    Boolean  @default(false)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@map("allergens")
}

model DietaryTag {
  id         String   @id @default(uuid())
  label      String
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@map("dietary_tags")
}

model NutritionSection {
  id         String   @id @default(uuid())
  title      String
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  rows       NutritionRow[]

  @@map("nutrition_sections")
}

model NutritionRow {
  id               String           @id @default(uuid())
  nutrient         String
  amount           String
  dailyValue       String?
  sub              Boolean          @default(false)
  sectionId        String
  section          NutritionSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@map("nutrition_rows")
}

model ModifierGroup {
  id            String   @id @default(uuid())
  name          String   
  isRequired    Boolean  @default(false)
  minSelections Int      @default(0)
  maxSelections Int?
  menuItemId    String
  menuItem      MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  options       ModifierOption[]

  @@map("modifier_groups")
}

model ModifierOption {
  id              String   @id @default(uuid())
  name            String   
  price           Float    @default(0) 
  groupId         String
  group           ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  
  @@map("modifier_options")
}

model OrderItemOption {
  id              String   @id @default(uuid())
  orderItemId     String
  orderItem       OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  optionName      String   
  optionPrice     Float
  
  @@map("order_item_options")
}

model Rating {
  id          String    @id @default(uuid())
  orderId     String
  menuItemId  String?
  rating      Int
  comment     String?
  customerRef String
  createdAt   DateTime  @default(now())
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem    MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([customerRef])
  @@map("ratings")
}

model PushSubscription {
  id          String   @id @default(uuid())
  customerRef String   @unique
  endpoint    String   @unique
  p256dh      String
  auth        String
  createdAt   DateTime @default(now())

  @@map("push_subscriptions")
}
