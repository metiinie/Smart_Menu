generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SubscriptionPlan {
  id           String       @id @default(uuid())
  name         String
  maxBranches  Int          @default(1)
  maxStaff     Int          @default(5)
  priceMonthly Float
  features     Json?
  createdAt    DateTime     @default(now())
  restaurants  Restaurant[]

  @@map("subscription_plans")
}

model Restaurant {
  id                 String             @id @default(uuid())
  slug               String             @unique
  name               String
  isActive           Boolean            @default(true)
  subscriptionStatus SubscriptionStatus @default(TRIALING)
  planId             String
  themeConfig        Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  branches           Branch[]
  categories         Category[]
  menuItems          MenuItem[]
  plan               SubscriptionPlan   @relation(fields: [planId], references: [id])
  users              User[]

  @@map("restaurants")
}

model Branch {
  id                String               @id @default(uuid())
  name              String
  address           String
  phone             String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  serviceChargeRate Float                @default(10.0)
  vatRate           Float                @default(15.0)
  restaurantId      String?
  orderCounters     BranchOrderCounter[]
  restaurant        Restaurant?          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categories        Category[]
  tables            DiningTable[]
  orderAudits       OrderAudit[]
  users             User[]

  @@index([restaurantId])
  @@map("branches")
}

model BranchOrderCounter {
  id          String   @id @default(uuid())
  branchId    String
  counterDate String
  lastNumber  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, counterDate])
  @@map("branch_order_counters")
}

model DiningTable {
  id           String         @id @default(uuid())
  branchId     String
  tableNumber  Int
  qrCode       String         @unique
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  restaurantId String?
  branch       Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  orderAudits  OrderAudit[]
  orders       Order[]
  sessions     TableSession[]

  @@unique([branchId, tableNumber])
  @@index([restaurantId])
  @@index([branchId])
  @@map("dining_tables")
}

/// Prevents order conflicts: only one active session per table at a time.
model TableSession {
  id          String       @id @default(uuid())
  tableId     String
  isActive    Boolean      @default(true)
  startedAt   DateTime     @default(now())
  endedAt     DateTime?
  orderAudits OrderAudit[]
  orders      Order[]
  table       DiningTable  @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@map("table_sessions")
}

model Category {
  id               String      @id @default(uuid())
  name             String
  sortOrder        Int         @default(0)
  imageUrl         String?
  branchId         String
  createdAt        DateTime    @default(now())
  nameTranslations Json?
  restaurantId     String?
  branch           Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  restaurant       Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items            MenuItem[]

  @@index([restaurantId])
  @@map("categories")
}

model MenuItem {
  id                      String             @id @default(uuid())
  name                    String
  description             String?
  price                   Float
  isAvailable             Boolean            @default(true)
  isFasting               Boolean            @default(false)
  imageUrl                String?
  categoryId              String
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  descriptionTranslations Json?
  model3dUrl              String?
  nameTranslations        Json?
  restaurantId            String?
  allergens               Allergen[]
  dietaryTags             DietaryTag[]
  favorites               Favorite[]
  ingredients             Ingredient[]
  category                Category           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  restaurant              Restaurant?        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  modifierGroups          ModifierGroup[]
  nutritionSections       NutritionSection[]
  orderItems              OrderItem[]
  ratings                 Rating[]

  @@index([restaurantId])
  @@map("menu_items")
}

model Order {
  id                  String       @id @default(uuid())
  tableId             String
  sessionId           String
  status              OrderStatus  @default(CREATED)
  totalPrice          Float
  customerRef         String
  notes               String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  displayNumber       String
  paymentStatus       String       @default("UNPAID")
  serviceChargeAmount Float        @default(0)
  subTotal            Float        @default(0)
  vatAmount           Float        @default(0)
  restaurantId        String?
  audits              OrderAudit[]
  items               OrderItem[]
  session             TableSession @relation(fields: [sessionId], references: [id])
  table               DiningTable  @relation(fields: [tableId], references: [id])
  ratings             Rating[]

  @@index([restaurantId])
  @@index([tableId])
  @@index([sessionId])
  @@map("orders")
}

model OrderItem {
  id         String            @id @default(uuid())
  orderId    String
  menuItemId String
  quantity   Int
  unitPrice  Float
  note       String?
  status     OrderItemStatus   @default(PENDING)
  options    OrderItemOption[]
  menuItem   MenuItem          @relation(fields: [menuItemId], references: [id])
  order      Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model User {
  id           String      @id @default(uuid())
  name         String
  role         Role
  pinHash      String?
  branchId     String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  email        String?     @unique
  restaurantId String?
  passwordHash String?
  branch       Branch?     @relation(fields: [branchId], references: [id])
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([email])
  @@map("staff_users")
}

model Ingredient {
  id         String   @id @default(uuid())
  name       String
  detail     String?
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@map("ingredients")
}

model Allergen {
  id         String   @id @default(uuid())
  label      String
  present    Boolean  @default(false)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@map("allergens")
}

model DietaryTag {
  id         String   @id @default(uuid())
  label      String
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@map("dietary_tags")
}

model NutritionSection {
  id         String         @id @default(uuid())
  title      String
  menuItemId String
  rows       NutritionRow[]
  menuItem   MenuItem       @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@map("nutrition_sections")
}

model NutritionRow {
  id         String           @id @default(uuid())
  nutrient   String
  amount     String
  dailyValue String?
  sub        Boolean          @default(false)
  sectionId  String
  section    NutritionSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@map("nutrition_rows")
}

model ModifierGroup {
  id            String           @id @default(uuid())
  name          String
  isRequired    Boolean          @default(false)
  minSelections Int              @default(0)
  maxSelections Int?
  menuItemId    String
  menuItem      MenuItem         @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  options       ModifierOption[]

  @@map("modifier_groups")
}

model ModifierOption {
  id      String        @id @default(uuid())
  name    String
  price   Float         @default(0)
  groupId String
  group   ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("modifier_options")
}

model OrderItemOption {
  id          String    @id @default(uuid())
  orderItemId String
  optionName  String
  optionPrice Float
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@map("order_item_options")
}

model Rating {
  id          String    @id @default(uuid())
  orderId     String
  menuItemId  String?
  rating      Int
  comment     String?
  customerRef String
  createdAt   DateTime  @default(now())
  menuItem    MenuItem? @relation(fields: [menuItemId], references: [id])
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([customerRef])
  @@map("ratings")
}

model PushSubscription {
  id          String   @id @default(uuid())
  customerRef String   @unique
  endpoint    String   @unique
  p256dh      String
  auth        String
  createdAt   DateTime @default(now())

  @@map("push_subscriptions")
}

model Favorite {
  id          String   @id @default(uuid())
  customerRef String
  menuItemId  String
  createdAt   DateTime @default(now())
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([customerRef, menuItemId])
  @@index([customerRef])
  @@map("favorites")
}

model OrderAudit {
  id            String        @id @default(uuid())
  branchId      String?
  tableId       String?
  sessionId     String?
  orderId       String?
  customerRef   String?
  displayNumber String?
  status        String
  source        String
  reason        String?
  itemCount     Int?
  createdAt     DateTime      @default(now())
  restaurantId  String?
  branch        Branch?       @relation(fields: [branchId], references: [id])
  order         Order?        @relation(fields: [orderId], references: [id])
  session       TableSession? @relation(fields: [sessionId], references: [id])
  table         DiningTable?  @relation(fields: [tableId], references: [id])

  @@index([restaurantId])
  @@index([branchId, createdAt])
  @@index([tableId, createdAt])
  @@index([sessionId, createdAt])
  @@index([orderId, createdAt])
  @@map("order_audits")
}

model FrontendErrorLog {
  id           String   @id @default(uuid())
  message      String
  stackTrace   String?
  url          String
  userAgent    String?
  resolved     Boolean  @default(false)
  createdAt    DateTime @default(now())
  
  // Optional context
  userId       String?
  restaurantId String?
  branchId     String?

  @@index([resolved, createdAt])
  @@index([restaurantId])
  @@map("frontend_error_logs")
}

enum OrderStatus {
  CREATED
  CONFIRMED
  PREPARING
  READY
  DELIVERED
}

enum Role {
  SUPER_ADMIN
  RESTAURANT_ADMIN
  MANAGER
  KITCHEN
  STAFF
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum OrderItemStatus {
  PENDING
  PREPARING
  READY
}
